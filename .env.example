POSTGRES_USER=lidocrm
POSTGRES_PASSWORD=changeme_strong
POSTGRES_DB=lidocrm

# URL для API/бота на **хосте** (см. порт postgres в docker-compose, при необходимости раскомментируйте 5432:5432).
# В `docker compose up` к api/bot подставляется `...@postgres:5432/...` — строка `...@localhost:5432` в контейнере неверна, см. docker-compose.
# DATABASE_URL=postgresql+asyncpg://lidocrm:changeme_strong@127.0.0.1:5432/lidocrm

API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
# Разработка: подробный API/SQL, в GET /health появляется "dev": true
DEV=true

# Origins веб-UI: Vite 5173, docker web (см. WEB_PORT) или прод-домен
# WEB_PORT=8080
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080,https://crm.example.com

# PUBLIC_API_BASE_URL=https://crm.example.com

TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_ALLOWED_USER_IDS=123456789

REMINDER_INTERVAL_SECONDS=60
APP_TIMEZONE=Europe/Moscow

# Веб-авторизация (JWT). В проде смените на длинный случайный секрет (≥32).
# AUTH_JWT_SECRET=...
# AUTH_JWT_EXPIRE_MINUTES=10080
# AUTH_ALLOW_REGISTRATION=true
