# Database (локально: localhost; Docker Compose: хост postgres — см. docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://lidocrm:lidocrm@localhost:5432/lidocrm
# В контейнерах api/bot URL переопределяется compose; в .env нужны TELEGRAM_* и опционально APP_TIMEZONE.

# API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# CORS (фронт Vite и продакшен-домен)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Telegram — from @BotFather
TELEGRAM_BOT_TOKEN=8697440684:AAEBO57bhUJIxMhtTHA_sHNqvI9BH423z6w

# Comma-separated Telegram user IDs allowed to use the bot (your account)
TELEGRAM_ALLOWED_USER_IDS=123456789

# Reminder polling interval (seconds) when running scheduler with the bot
REMINDER_INTERVAL_SECONDS=60

# IANA timezone for tasks "today" and digest boundaries
APP_TIMEZONE=Europe/Moscow
